<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MedAI" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/orange_500</item>
        <item name="colorPrimaryVariant">@color/orange_600</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/orange_500</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_sidebar</item>
        <item name="android:navigationBarColor">@color/bg_sidebar</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:fontFamily">@font/sora_regular</item>
    </style>

    <style name="Theme.MedAI.Splash" parent="Theme.MedAI">
        <item name="android:windowSplashScreenBackground">@color/bg_primary</item>
    </style>

    <!-- Light override colors -->
    <style name="Theme.MedAI.Light" parent="Theme.MedAI">
        <item name="android:windowBackground">@color/login_bg</item>
    </style>
</resources>
